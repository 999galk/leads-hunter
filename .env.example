# Copy this file to .env and fill in your values

# DEV_MODE: true  = cheaper models where possible (Claude Haiku for Copywriter)
#           false = production-quality models (Claude Sonnet for Copywriter)
DEV_MODE=true

# OpenAI — Hunter, Qualifier, Evaluator
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — Copywriter
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apollo API key — swap _load_profiles() in servers/linkedin_mock_server.py to use live data
APOLLO_API_KEY=

# Dry run mode — always true for this POC (no real messages are ever sent)
DRY_RUN=true

# Sender identity — used by the Copywriter in email sign-offs and LinkedIn invites
SENDER_NAME="Your Name"
SENDER_TITLE="Solutions Architect"

# CrewAI tracing — keep off for local runs (disables telemetry upload)
CREWAI_TRACING_ENABLED=false