# Copy this file to .env and fill in your values

# DEV_MODE: true = cheap/fast models (Groq + gpt-4o-mini) for development
#           false = production-quality models (gpt-4o + Claude) for submission
DEV_MODE=true

# OpenAI — default LLM for Qualifier, Copywriter, Evaluator, Reporter
OPENAI_API_KEY=your_openai_api_key_here

# Groq — used for Hunter agent (near-free, fast)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Anthropic — optional, swap in Copywriter for higher writing quality
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apollo API key — swap _load_profiles() in servers/linkedin_mock_server.py to use live data
APOLLO_API_KEY=

# Dry run mode — always true for this POC (no real messages sent)
DRY_RUN=true
